{
  "action": [
    {
      "command": "generate",
      "generator": "syft",
      "stop_on_error": false,
      "flags": {
        "input": "./my-project",
        "output": "cyclonedx-json",
        "file": "/tmp/sbom-syft.json"
      }
    },
    {
      "command": "generate",
      "generator": "csbom",
      "stop_on_error": false,
      "flags": {
        "input": "./my-project",
        "output": "cyclonedx-json",
        "file": "/tmp/sbom-csbom.json"
      }
    },
    {
      "command": "merge",
      "stop_on_error": true,
      "flags": {
        "input_files": ["/tmp/sbom-syft.json", "/tmp/sbom-csbom.json"],
        "file": "merged.json",
        "output": "cyclonedx-1.6"
      }
    }
  ]
}
